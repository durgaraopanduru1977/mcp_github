# Copy to .env and fill in real values. .env is gitignored and must never be committed.

# GitHub account these tools operate against when a bare repo name is given.
GITHUB_OWNER="your-github-username"

# GitHub Personal Access Token.
# Optional for reading public repos; required for private repos, higher rate
# limits, and write actions (e.g. creating issues).
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=""
